# NebGov Stellar testnet deployment environment
# Copy to .env.testnet, review the identity/token choices, then run:
#   ./scripts/deploy-testnet.sh
#
# Testnet timing assumes approximately 5 seconds per ledger. Mainnet timing
# should usually be longer and should be chosen through governance policy.

# ----- Stellar identity and network -----

# Required. stellar-cli identity used to sign deployments and initialization.
# The deploy script creates and funds this identity on testnet if it is missing.
# Testnet recommendation: deployer. Mainnet recommendation: use a secured signer.
STELLAR_IDENTITY=deployer

# Required. stellar-cli network name. Use testnet for this file.
# Acceptable values depend on local stellar-cli network config.
STELLAR_NETWORK=testnet

# Optional. RPC endpoint used by indexers, SDK tests, and local tooling.
# Testnet recommendation: public Soroban testnet RPC. Mainnet should use a
# production-grade provider with rate limits appropriate for your traffic.
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
TESTNET_RPC_URL=https://soroban-testnet.stellar.org

# Optional. Secret key for SDK integration tests only. Never commit a funded key.
TESTNET_SECRET_KEY=

# ----- Governance token -----

# Optional. Existing SEP-41 token contract used by token-votes.
# Leave empty to use the deploy script's Stellar testnet native XLM default.
# Mainnet recommendation: set this explicitly to the production governance token.
SEP41_TOKEN_ADDRESS=

# ----- Contract addresses populated by scripts/deploy-testnet.sh -----

# Optional before deployment, required after deployment for apps/indexers.
# Leave empty for a fresh deployment; the deploy script persists each address.
TOKEN_VOTES_ADDRESS=
TIMELOCK_ADDRESS=
GOVERNOR_ADDRESS=
TREASURY_ADDRESS=
FACTORY_ADDRESS=

# Frontend aliases. Optional for deployment; required for the Next.js app.
NEXT_PUBLIC_VOTES_ADDRESS=
NEXT_PUBLIC_TIMELOCK_ADDRESS=
NEXT_PUBLIC_GOVERNOR_ADDRESS=

# ----- Governor defaults -----

# Required. Voting delay in ledgers.
# Testnet recommendation: 60 ledgers, about 5 minutes.
# Mainnet recommendation: use a longer review window, commonly hours to days.
VOTING_DELAY=60

# Required. Voting period in ledgers.
# Testnet recommendation: 1440 ledgers, about 2 hours.
# Mainnet recommendation: use a longer period, commonly several days.
VOTING_PERIOD=1440

# Required. Quorum numerator as a whole-number percentage from 0 to 100.
# Testnet recommendation: 4 = 4%. Mainnet recommendation: protocol-specific.
QUORUM_NUMERATOR=4

# Required. Minimum voting power needed to create a proposal, in token base units.
# Example assumes 7 token decimals: 100000000 = 10 tokens.
# Testnet recommendation: keep low enough for test accounts.
PROPOSAL_THRESHOLD=100000000

# ----- Timelock defaults -----

# Required. Minimum execution delay in seconds after a proposal is queued.
# Testnet recommendation: 300 seconds for quick validation.
# Mainnet recommendation: 86400 seconds or longer, depending on risk tolerance.
TIMELOCK_MIN_DELAY=300

# Optional. Execution window in seconds after the timelock delay elapses.
# Testnet recommendation: 86400 seconds. Mainnet recommendation: long enough
# for operators to execute safely, short enough to avoid stale actions.
TIMELOCK_EXECUTION_WINDOW=86400

# ----- Treasury defaults -----

# Required. Number of owner approvals required for treasury actions.
# Acceptable range: 1 through the number of configured owners.
# The testnet deploy script initializes one owner, so the default is 1.
TREASURY_THRESHOLD=1

# ----- Local app, backend, and indexer settings -----

# Optional. Browser-visible Stellar network for the Next.js app.
NEXT_PUBLIC_NETWORK=testnet

# Optional. Backend URL as seen by the browser.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Optional. Indexer polling interval in milliseconds.
POLL_INTERVAL_MS=5000

# Optional. Local service ports.
APP_PORT=3000
BACKEND_PORT=3001
INDEXER_PORT=3002
POSTGRES_PORT=5432

# Optional. Local Postgres defaults for docker-compose.
POSTGRES_DB=nebgov
POSTGRES_USER=nebgov
POSTGRES_PASSWORD=nebgov

# Optional. Local backend auth secret. Replace for shared environments.
JWT_SECRET=dev-secret
